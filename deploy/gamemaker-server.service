[Unit]
Description=Servidor de lobby y chat del juego GameMaker
After=network.target

[Service]
Type=simple
User=ivan
WorkingDirectory=/home/ivan/Prueba-server-gamemaker/server
ExecStart=/usr/bin/node server.js
Environment=NODE_ENV=production
UMask=0077
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
